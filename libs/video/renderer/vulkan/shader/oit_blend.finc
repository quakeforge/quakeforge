#include "oit.h"

#ifdef __RUAMOKO__
#include "GLSL/image.h"
#endif

void printf (string fmt, ...)
    = @intrinsic(OpExtInst, "NonSemantic.DebugPrintf", DebugPrintf);

bool
cmp (const FragData fd1, const FragData fd2)
{
	// reverse depth buffer
	return fd1.depth < fd2.depth;
}

#define MAX_FRAGMENTS 7

#define get_sind(ind, ele, nele) \
{ \
	s_ind = n_ind; \
	uint l_ind = 2 * n_ind + 1; \
	uint r_ind = 2 * n_ind + 2; \
	if (l_ind < nele && cmp (ele[l_ind], ele[n_ind])) { \
		s_ind = l_ind; \
	} \
	if (r_ind < nele && cmp (ele[r_ind], ele[s_ind])) { \
		s_ind = r_ind; \
	} \
}

#define swap(ele, i1, i2) \
{ \
	auto t = ele[i1]; \
	ele[i1] = ele[i2]; \
	ele[i2] = t; \
}

#define sink(ele, nele) \
{ \
	uint n_ind = 0; \
	uint s_ind; \
	get_sind (n_ind, ele, nele); \
	while (s_ind != n_ind) { \
		swap (ele, n_ind, s_ind) \
		n_ind = s_ind; \
		get_sind (n_ind, ele, nele); \
	} \
}

#define swim(ele, nele) \
{ \
	uint n_ind = nele - 1; \
	while (n_ind > 0) { \
		uint p_ind = (n_ind - 1) / 2; \
		if (!cmp (ele[n_ind], ele[p_ind])) { \
			break; \
		} \
		swap (ele, n_ind, p_ind) \
		n_ind = p_ind; \
	} \
} \

vec4
BlendFrags (vec4 color)
{
	FragData    frags[MAX_FRAGMENTS];
	uint        numFrags = 0;
	int         maxIter = 64;	//FIXME why does this fix things locking up
								// at startup? the loop doesn't get entered.
								// qfcc bug? However, only nq/qw. qwaq is ok
	ivec3       coord = ivec3(gl_FragCoord.xy, gl_ViewIndex);
	int         index = imageLoad (heads, coord).r;

	while (index != -1 && maxIter-- > 0) {
		if (numFrags < MAX_FRAGMENTS) {
			frags[numFrags++] = fragments[index];
			swim (frags, numFrags);
		} else if (!cmp (fragments[index], frags[0])) {
			frags[0] = fragments[index];
			sink (frags, numFrags);
		}
		index = fragments[index].next;
	}

	for (uint i = numFrags; i-- > 0; ) {
		auto f = frags[0];
		frags[0] = frags[i];
		sink (frags, i);
		color = mix (color, f.color, clamp (f.color.a, 0.0f, 1.0f));
	}
	return color;
}
